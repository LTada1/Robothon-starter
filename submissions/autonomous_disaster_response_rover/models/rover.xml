<mujoco model="autonomous_disaster_response_rover">
  <compiler angle="radian" coordinate="local"/>
  <option timestep="0.002" gravity="0 0 -9.81" iterations="80" solver="Newton"/>

  <visual>
    <global offwidth="1280" offheight="720"/>
    <quality shadowsize="2048"/>
    <map force="0.1" znear="0.01"/>
  </visual>

  <asset>
    <texture name="grid" type="2d" builtin="checker" rgb1="0.12 0.13 0.14" rgb2="0.18 0.19 0.20"
             width="512" height="512"/>
    <material name="disaster_floor" texture="grid" texrepeat="5 5" reflectance="0.12"/>
  </asset>

  <default>
    <geom solref="0.012 1" solimp="0.9 0.95 0.001"/>
    <default class="rover_wheel">
      <joint type="hinge" axis="0 1 0" damping="2.0" frictionloss="0.35"/>
      <geom type="cylinder" size="0.16 0.055" mass="2.0" rgba="0.03 0.035 0.04 1"
            friction="1.6 0.04 0.01" condim="3"/>
    </default>
  </default>

  <worldbody>
    <light name="key_light" pos="0 -3 4" dir="0 0.6 -1" diffuse="0.9 0.9 0.85"/>
    <light name="fill_light" pos="-3 2 2" dir="0.8 -0.4 -1" diffuse="0.35 0.40 0.45"/>
    <camera name="overview_camera" pos="2.8 -3.0 1.8" xyaxes="0.72 0.69 0 -0.32 0.34 0.88"/>

    <geom name="floor" type="plane" size="8 8 0.05" material="disaster_floor"
          friction="1.4 0.08 0.02" condim="4"/>

    <body name="rover" pos="0 0 0.24">
      <freejoint name="rover_freejoint"/>
      <site name="rover_center_site" pos="0 0 0" size="0.015" rgba="1 1 1 0"/>

      <geom name="rover_chassis_collision" type="box" size="0.42 0.28 0.10" mass="28"
            rgba="0.18 0.22 0.26 0.18" contype="1" conaffinity="1"
            friction="1.2 0.05 0.01"/>
      <geom name="rover_chassis_visual" type="box" size="0.44 0.30 0.09" mass="0"
            pos="0 0 0.015" rgba="0.18 0.28 0.36 1" contype="0" conaffinity="0"/>
      <geom name="rover_top_plate_visual" type="box" size="0.32 0.22 0.025" mass="0"
            pos="0.02 0 0.125" rgba="0.90 0.52 0.12 1" contype="0" conaffinity="0"/>
      <geom name="rover_front_bumper" type="box" size="0.035 0.31 0.055" mass="2.0"
            pos="0.47 0 -0.005" rgba="0.05 0.06 0.07 1" friction="1.0 0.05 0.01"/>
      <geom name="rover_rear_bumper" type="box" size="0.025 0.29 0.045" mass="1.5"
            pos="-0.46 0 -0.01" rgba="0.05 0.06 0.07 1" friction="1.0 0.05 0.01"/>

      <body name="forward_lidar_mount" pos="0.46 0 0.18">
        <geom name="forward_lidar_mount_visual" type="cylinder" size="0.045 0.035" mass="0.15"
              euler="1.5708 0 0" rgba="0.10 0.13 0.15 1" contype="0" conaffinity="0"/>
        <site name="forward_lidar_site" pos="0.045 0 0" size="0.02" rgba="0.2 0.8 1 1"/>
      </body>

      <body name="left_proximity_sensor_mount" pos="0.20 0.32 0.06">
        <geom name="left_proximity_sensor_visual" type="sphere" size="0.025" mass="0.05"
              rgba="0.10 0.45 1.00 1" contype="0" conaffinity="0"/>
        <site name="left_proximity_sensor_site" pos="0 0.02 0" size="0.015" rgba="0.2 0.8 1 1"/>
      </body>

      <body name="right_proximity_sensor_mount" pos="0.20 -0.32 0.06">
        <geom name="right_proximity_sensor_visual" type="sphere" size="0.025" mass="0.05"
              rgba="0.10 0.45 1.00 1" contype="0" conaffinity="0"/>
        <site name="right_proximity_sensor_site" pos="0 -0.02 0" size="0.015" rgba="0.2 0.8 1 1"/>
      </body>

      <body name="camera_mount" pos="0.18 0 0.28">
        <geom name="camera_mount_visual" type="box" size="0.06 0.04 0.035" mass="0.1"
              rgba="0.02 0.025 0.03 1" contype="0" conaffinity="0"/>
        <site name="camera_mount_site" pos="0.08 0 0.02" size="0.018" rgba="1 0.8 0.2 1"/>
        <camera name="rover_front_camera" pos="0.08 0 0.02" xyaxes="0 -1 0 0.12 0 0.99"/>
      </body>

      <body name="rescue_deployer" pos="0.49 0 0.03">
        <joint name="rescue_deployer_joint" type="hinge" axis="0 1 0" range="0 0.65"
               damping="1.4" frictionloss="0.08" limited="true"/>
        <geom name="rescue_deployer_arm" type="capsule" fromto="0 0 0 0.34 0 -0.04"
              size="0.018" mass="0.18" rgba="0.05 0.62 0.42 1"
              contype="0" conaffinity="0"/>
        <geom name="rescue_deployer_pad" type="box" pos="0.37 0 -0.045"
              size="0.045 0.16 0.018" mass="0.12" rgba="0.05 0.78 0.52 1"
              contype="0" conaffinity="0"/>
        <site name="rescue_tool_site" pos="0.40 0 -0.045" size="0.025" rgba="0.05 1 0.64 1"/>
      </body>

      <body name="left_front_wheel" pos="0.30 0.33 -0.08">
        <joint name="left_front_wheel_joint" class="rover_wheel"/>
        <geom name="left_front_wheel_geom" class="rover_wheel" euler="1.5708 0 0"/>
      </body>

      <body name="left_rear_wheel" pos="-0.30 0.33 -0.08">
        <joint name="left_rear_wheel_joint" class="rover_wheel"/>
        <geom name="left_rear_wheel_geom" class="rover_wheel" euler="1.5708 0 0"/>
      </body>

      <body name="right_front_wheel" pos="0.30 -0.33 -0.08">
        <joint name="right_front_wheel_joint" class="rover_wheel"/>
        <geom name="right_front_wheel_geom" class="rover_wheel" euler="1.5708 0 0"/>
      </body>

      <body name="right_rear_wheel" pos="-0.30 -0.33 -0.08">
        <joint name="right_rear_wheel_joint" class="rover_wheel"/>
        <geom name="right_rear_wheel_geom" class="rover_wheel" euler="1.5708 0 0"/>
      </body>
    </body>
  </worldbody>

  <actuator>
    <velocity name="left_front_wheel_velocity" joint="left_front_wheel_joint" kv="1.6" ctrlrange="-3 3"/>
    <velocity name="left_rear_wheel_velocity" joint="left_rear_wheel_joint" kv="1.6" ctrlrange="-3 3"/>
    <velocity name="right_front_wheel_velocity" joint="right_front_wheel_joint" kv="1.6" ctrlrange="-3 3"/>
    <velocity name="right_rear_wheel_velocity" joint="right_rear_wheel_joint" kv="1.6" ctrlrange="-3 3"/>
    <position name="rescue_deployer_actuator" joint="rescue_deployer_joint" kp="3.0"
              ctrlrange="0 0.65" forcerange="-2 2"/>
  </actuator>

  <sensor>
    <framepos name="rover_pose_sensor" objtype="body" objname="rover"/>
    <framequat name="rover_orientation_sensor" objtype="body" objname="rover"/>
    <velocimeter name="rover_velocity_sensor" site="rover_center_site"/>
  </sensor>
</mujoco>
